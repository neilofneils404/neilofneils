---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => data.published !== false);
  return posts.map((post) => ({ params: { slug: post.id.replace(/\.md$/, '') }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<BaseLayout title={post.data.title} description={post.data.summary}>
  <article class="article-shell">
    <div class="article-header">
      <p class="eyebrow">{post.data.date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
      <h1>{post.data.title}</h1>
      <p class="article-summary">{post.data.summary}</p>
      {post.data.image && (
        <figure class="article-cover">
          <div class="article-cover-media">
            <img src={post.data.image} alt={post.data.title} />
          </div>
        </figure>
      )}
    </div>
    <div class="article-body">
      <Content />
    </div>
  </article>
</BaseLayout>
